            <column-instance column='[Calculation_1999879755130912773]' derivation='None' name='[none:Calculation_1999879755130912773:nk]' pivot='key' type='nominal' />
            <column-instance column='[F1]' derivation='None' name='[none:F1:nk]' pivot='key' type='nominal' />
