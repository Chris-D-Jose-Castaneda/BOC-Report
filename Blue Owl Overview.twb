            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0phgxtj12wyw3g1ecf00816m1rqa'>
            <column caption='CNI YoY %' datatype='real' name='[Calculation_182677305931489293]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG( IF [year] = [Parameters].[Parameter 2] THEN [Net Income (Consolidated) YoY %] END )' />
            </column>
            <column caption='CNI Direction' datatype='string' name='[Calculation_182677305931595790]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_182677305931489293] &gt; 0 THEN &quot;Up&quot;&#13;&#10;ELSEIF [Calculation_182677305931489293] &lt; 0 THEN &quot;Down&quot;&#13;&#10;ELSE &quot;Flat&quot;&#13;&#10;END' />
            </column>
            <column caption='CNI Arrow' datatype='string' name='[Calculation_182677305931661327]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_182677305931489293] &gt; 0 THEN &quot;▲&quot;&#13;&#10;ELSEIF [Calculation_182677305931489293] &lt; 0 THEN &quot;▼&quot;&#13;&#10;ELSE &quot;–&quot;&#13;&#10;END' />
            </column>
            <column caption='CPI YoY (colored)' datatype='string' name='[Calculation_182677305932505106]' role='measure' type='nominal'>
              <calculation class='tableau' formula='[Calculation_182677305931661327] + &quot; &quot; + STR(ROUND([Calculation_182677305931489293]*100,1)) + &quot;% YoY&quot;' />
            </column>
            <column datatype='real' name='[Net Income (Consolidated) YoY %]' role='measure' type='quantitative' />
