      <aliases enabled='yes' />
      <column caption='Amount Year' datatype='real' name='[Calculation_182677305949392926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Amount (pYear)&#13;&#10;CASE [Parameters].[Parameter 2]&#13;&#10;    WHEN 2020 THEN [DEC &apos;20]&#13;&#10;    WHEN 2021 THEN [DEC &apos;21]&#13;&#10;    WHEN 2022 THEN [DEC &apos;22]&#13;&#10;    WHEN 2023 THEN [DEC &apos;23]&#13;&#10;    WHEN 2024 THEN [DEC &apos;24]&#13;&#10;    WHEN 2025 THEN [DEC &apos;25]&#13;&#10;END' />
      </column>
      <column caption='Waterfall Color' datatype='string' name='[Calculation_182677305950965793]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// Waterfall Color&#13;&#10;IF ATTR([line_item]) = &quot;Consolidated Net Income&quot;&#13;&#10;THEN &quot;Total&quot;&#13;&#10;&#13;&#10;ELSEIF ATTR([line_item]) = &quot;Gross Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Pretax Income&quot;&#13;&#10;THEN &quot;Subtotal&quot;&#13;&#10;&#13;&#10;ELSEIF ATTR([line_item]) = &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;&#13;&#10;OR ATTR([line_item]) = &quot;SG&amp;A Expense&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Interest Expense&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Income Taxes&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Unusual Expense - Net&quot;&#13;&#10;THEN &quot;Expense&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Calculation_182677305954807846]) &gt;= 0&#13;&#10;THEN &quot;Positive&quot;&#13;&#10;&#13;&#10;ELSE &quot;Expense&quot;&#13;&#10;END' />
      </column>
      <column caption='WF Delta' datatype='real' name='[Calculation_182677305953386530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Delta&#13;&#10;IF [line_item] = &quot;Gross Income&quot;&#13;&#10;OR [line_item] = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR [line_item] = &quot;Pretax Income&quot;&#13;&#10;OR [line_item] = &quot;Consolidated Net Income&quot;&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;&#13;&#10;OR [line_item] = &quot;SG&amp;A Expense&quot;&#13;&#10;OR [line_item] = &quot;Interest Expense&quot;&#13;&#10;OR [line_item] = &quot;Income Taxes&quot;&#13;&#10;OR [line_item] = &quot;Unusual Expense - Net&quot;&#13;&#10;THEN -ABS([Calculation_182677305949392926])&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Other Income (Expense)&quot;&#13;&#10;THEN [Calculation_182677305949392926]&#13;&#10;&#13;&#10;ELSE [Calculation_182677305949392926]&#13;&#10;END' />
      </column>
      <column caption='WF Start' datatype='real' name='[Calculation_182677305953521699]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Start&#13;&#10;IF ATTR([line_item]) = &quot;Gross Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Pretax Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Consolidated Net Income&quot;&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSE&#13;&#10;    RUNNING_SUM(SUM([Calculation_182677305954807846])) - SUM([Calculation_182677305954807846])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='WF Size' datatype='real' name='[Calculation_182677305953570852]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Size&#13;&#10;IF ATTR([line_item]) = &quot;Gross Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Pretax Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Consolidated Net Income&quot;&#13;&#10;THEN RUNNING_SUM(SUM([Calculation_182677305954807846]))&#13;&#10;&#13;&#10;ELSE&#13;&#10;    SUM([Calculation_182677305954807846])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='WF Label' datatype='real' name='[Calculation_182677305953615909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Label&#13;&#10;IF ATTR([line_item]) = &quot;Gross Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Pretax Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Consolidated Net Income&quot;&#13;&#10;THEN RUNNING_SUM(SUM([Calculation_182677305954807846]))&#13;&#10;&#13;&#10;ELSE&#13;&#10;    SUM([Calculation_182677305954807846])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='WF Signed Amount' datatype='real' name='[Calculation_182677305954807846]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Signed Amount&#13;&#10;IF [line_item] = &quot;Gross Income&quot;&#13;&#10;OR [line_item] = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR [line_item] = &quot;Pretax Income&quot;&#13;&#10;OR [line_item] = &quot;Consolidated Net Income&quot;&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;&#13;&#10;OR [line_item] = &quot;SG&amp;A Expense&quot;&#13;&#10;OR [line_item] = &quot;Interest Expense&quot;&#13;&#10;OR [line_item] = &quot;Income Taxes&quot;&#13;&#10;OR [line_item] = &quot;Unusual Expense - Net&quot;&#13;&#10;THEN -ABS([Calculation_182677305949392926])&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Other Income (Expense)&quot;&#13;&#10;THEN [Calculation_182677305949392926]&#13;&#10;&#13;&#10;ELSE&#13;&#10;    [Calculation_182677305949392926]&#13;&#10;END' />
      </column>
      <column caption='WF Order' datatype='integer' name='[Calculation_182677305955119143]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// WF Order&#13;&#10;CASE [line_item]&#13;&#10;WHEN &quot;Sales&quot; THEN 1&#13;&#10;WHEN &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot; THEN 2&#13;&#10;WHEN &quot;Gross Income&quot; THEN 3&#13;&#10;WHEN &quot;SG&amp;A Expense&quot; THEN 4&#13;&#10;WHEN &quot;EBIT (Operating Income)&quot; THEN 5&#13;&#10;WHEN &quot;Nonoperating Interest Income&quot; THEN 6&#13;&#10;WHEN &quot;Other Income (Expense)&quot; THEN 7&#13;&#10;WHEN &quot;Interest Expense&quot; THEN 8&#13;&#10;WHEN &quot;Unusual Expense - Net&quot; THEN 9&#13;&#10;WHEN &quot;Pretax Income&quot; THEN 10&#13;&#10;WHEN &quot;Income Taxes&quot; THEN 11&#13;&#10;WHEN &quot;Consolidated Net Income&quot; THEN 12&#13;&#10;END' />
      </column>
      <column caption='Line Item Indented' datatype='string' name='[Calculation_1999879755121246209]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([line_item]), &quot;total&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;net income&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;gross&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;ebit&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;assets&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;liabilities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;equity&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;operating activities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;investing activities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;financing activities&quot;)&#13;&#10;THEN [line_item]&#13;&#10;ELSE CHAR(9) + [line_item]&#13;&#10;END' />
      </column>
