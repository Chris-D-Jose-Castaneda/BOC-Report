      <aliases enabled='yes' />
      <column caption='Indent Level IS' datatype='integer' name='[Calculation_182677305803567104]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [F1]&#13;&#10;&#13;&#10;/* Level 0: section headers */&#13;&#10;WHEN &quot;Per Share&quot; THEN 0&#13;&#10;&#13;&#10;/* Level 0: key statement lines */&#13;&#10;WHEN &quot;Sales&quot; THEN 0&#13;&#10;WHEN &quot;Gross Income&quot; THEN 0&#13;&#10;WHEN &quot;EBIT (Operating Income)&quot; THEN 0&#13;&#10;WHEN &quot;Pretax Income&quot; THEN 0&#13;&#10;WHEN &quot;Consolidated Net Income&quot; THEN 0&#13;&#10;WHEN &quot;Net Income&quot; THEN 0&#13;&#10;WHEN &quot;Net Income available to Common&quot; THEN 0&#13;&#10;&#13;&#10;/* Level 1: children under key lines */&#13;&#10;WHEN &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot; THEN 1&#13;&#10;WHEN &quot;SG&amp;A Expense&quot; THEN 1&#13;&#10;WHEN &quot;Nonoperating Interest Income&quot; THEN 1&#13;&#10;WHEN &quot;Other Income (Expense)&quot; THEN 1&#13;&#10;WHEN &quot;Interest Expense&quot; THEN 1&#13;&#10;WHEN &quot;Income Taxes&quot; THEN 1&#13;&#10;WHEN &quot;Minority Interest&quot; THEN 1&#13;&#10;&#13;&#10;/* Level 1: per-share */&#13;&#10;WHEN &quot;EPS (basic)&quot; THEN 1&#13;&#10;WHEN &quot;EPS (diluted)&quot; THEN 1&#13;&#10;WHEN &quot;Dividends per Share&quot; THEN 1&#13;&#10;WHEN &quot;Basic Shares Outstanding&quot; THEN 1&#13;&#10;WHEN &quot;Diluted Shares Outstanding&quot; THEN 1&#13;&#10;&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='Indent Label' datatype='string' name='[Calculation_182677305803657217]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPACE([Calculation_182677305803567104] * 4) + [F1]' />
      </column>
      <column caption='IS Highlighted Group' datatype='string' name='[Calculation_182677305808211972]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [F1] IN (&quot;Sales&quot;, &quot;EBIT (Operating Income)&quot;, &quot;EBITDA&quot;, &quot;Consolidated Net Income&quot;) THEN&#13;&#10;    &quot;A: Major&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&#13;&#10;    &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;,&#13;&#10;    &quot;Gross Income&quot;,&#13;&#10;    &quot;SG&amp;A Expense&quot;&#13;&#10;) THEN&#13;&#10;    &quot;B: Operating Build (light)&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&#13;&#10;    &quot;Pretax Income&quot;,&#13;&#10;    &quot;Income Taxes&quot;&#13;&#10;) THEN&#13;&#10;    &quot;C: Consolidated NI Build (light)&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Z: Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Statement Filter' datatype='string' name='[Calculation_182677305817022471]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
      </column>
      <column caption='▲ Positive' datatype='real' name='[Calculation_182677305868951561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Net Income % Change] &gt; 0 THEN &quot;▲&quot; END' />
      </column>
      <column caption='▼ Negative' datatype='real' name='[Calculation_182677305869049866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Net Income % Change] &lt; 0 THEN &quot;▼&quot; END' />
      </column>
      <column caption='Indented Label' datatype='string' name='[Calculation_1999879755159040008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPACE([Calculation_1999879755159560201]*4) + [F1]' />
      </column>
      <column caption='Indent Level' datatype='integer' name='[Calculation_1999879755159560201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [F1]&#13;&#10;&#13;&#10;/* ===== Level 0: Section headers (no indent) ===== */&#13;&#10;WHEN &quot;Assets&quot; THEN 0&#13;&#10;WHEN &quot;Liabilities &amp; Shareholders&apos; Equity&quot; THEN 0&#13;&#10;WHEN &quot;Per Share&quot; THEN 0&#13;&#10;&#13;&#10;/* ===== Level 1: Subheaders (slight indent) ===== */&#13;&#10;WHEN &quot;Current&quot; THEN 1&#13;&#10;WHEN &quot;Long-Term&quot; THEN 1&#13;&#10;WHEN &quot;Equity&quot; THEN 1&#13;&#10;&#13;&#10;/* ===== Level 1: Key subtotals / totals (keep close to header) ===== */&#13;&#10;WHEN &quot;Total Current Assets&quot; THEN 1&#13;&#10;WHEN &quot;Total Assets&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Total Current Liabilities&quot; THEN 1&#13;&#10;WHEN &quot;Total Liabilities&quot; THEN 1&#13;&#10;WHEN &quot;Total Shareholders’ Equity&quot; THEN 1&#13;&#10;WHEN &quot;Total Equity&quot; THEN 1&#13;&#10;WHEN &quot;Total Liabilities &amp; Shareholders’ Equity&quot; THEN 1&#13;&#10;&#13;&#10;/* ===== Level 2: Detail lines (fully indented) ===== */&#13;&#10;/* Assets detail */&#13;&#10;WHEN &quot;Cash &amp; Short-Term Investments&quot; THEN 2&#13;&#10;WHEN &quot;Short-Term Receivables&quot; THEN 2&#13;&#10;WHEN &quot;Net Property, Plant &amp; Equipment&quot; THEN 2&#13;&#10;WHEN &quot;Total Long-Term Investments&quot; THEN 2&#13;&#10;WHEN &quot;Intangible Assets&quot; THEN 2&#13;&#10;WHEN &quot;Deferred Tax Assets&quot; THEN 2&#13;&#10;WHEN &quot;Other Assets&quot; THEN 2&#13;&#10;&#13;&#10;/* Liabilities detail */&#13;&#10;WHEN &quot;Other Current Liabilities&quot; THEN 2&#13;&#10;WHEN &quot;Long-Term Debt&quot; THEN 2&#13;&#10;WHEN &quot;Deferred Tax Liabilities&quot; THEN 2&#13;&#10;WHEN &quot;Other Liabilities&quot; THEN 2&#13;&#10;&#13;&#10;/* Equity detail */&#13;&#10;WHEN &quot;Common Equity&quot; THEN 2&#13;&#10;WHEN &quot;Retained Earnings&quot; THEN 2&#13;&#10;WHEN &quot;Accumulated Minority Interest&quot; THEN 2&#13;&#10;&#13;&#10;/* Per share detail */&#13;&#10;WHEN &quot;Book Value per Share&quot; THEN 2&#13;&#10;WHEN &quot;Tangible Book Value per Share&quot; THEN 2&#13;&#10;&#13;&#10;/* ===== Default ===== */&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
