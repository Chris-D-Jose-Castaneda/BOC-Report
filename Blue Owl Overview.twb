    <worksheet name='Income Statement'>
      <table>
        <view>
          <datasources>
            <datasource caption='OWL-US (Blue Owl Net Income)' name='federated.1fhy3tw1x76j2h1ctexvr0ggkdc7' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Financial Statement' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Income Statement&quot;'>
              <calculation class='tableau' formula='&quot;Income Statement&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1fhy3tw1x76j2h1ctexvr0ggkdc7'>
            <column caption='Indent Level IS' datatype='integer' name='[Calculation_182677305803567104]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [F1]&#13;&#10;&#13;&#10;/* Level 0: section headers */&#13;&#10;WHEN &quot;Per Share&quot; THEN 0&#13;&#10;&#13;&#10;/* Level 0: key statement lines */&#13;&#10;WHEN &quot;Sales&quot; THEN 0&#13;&#10;WHEN &quot;Gross Income&quot; THEN 0&#13;&#10;WHEN &quot;EBIT (Operating Income)&quot; THEN 0&#13;&#10;WHEN &quot;Pretax Income&quot; THEN 0&#13;&#10;WHEN &quot;Consolidated Net Income&quot; THEN 0&#13;&#10;WHEN &quot;Net Income&quot; THEN 0&#13;&#10;WHEN &quot;Net Income available to Common&quot; THEN 0&#13;&#10;&#13;&#10;/* Level 1: children under key lines */&#13;&#10;WHEN &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot; THEN 1&#13;&#10;WHEN &quot;SG&amp;A Expense&quot; THEN 1&#13;&#10;WHEN &quot;Nonoperating Interest Income&quot; THEN 1&#13;&#10;WHEN &quot;Other Income (Expense)&quot; THEN 1&#13;&#10;WHEN &quot;Interest Expense&quot; THEN 1&#13;&#10;WHEN &quot;Income Taxes&quot; THEN 1&#13;&#10;WHEN &quot;Minority Interest&quot; THEN 1&#13;&#10;&#13;&#10;/* Level 1: per-share */&#13;&#10;WHEN &quot;EPS (basic)&quot; THEN 1&#13;&#10;WHEN &quot;EPS (diluted)&quot; THEN 1&#13;&#10;WHEN &quot;Dividends per Share&quot; THEN 1&#13;&#10;WHEN &quot;Basic Shares Outstanding&quot; THEN 1&#13;&#10;WHEN &quot;Diluted Shares Outstanding&quot; THEN 1&#13;&#10;&#13;&#10;ELSE 1&#13;&#10;END' />
            </column>
            <column caption='Indent Label' datatype='string' name='[Calculation_182677305803657217]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='SPACE([Calculation_182677305803567104] * 4) + [F1]' />
            </column>
            <column caption='IS Highlighted Group' datatype='string' name='[Calculation_182677305808211972]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [F1] IN (&quot;Sales&quot;, &quot;EBIT (Operating Income)&quot;, &quot;EBITDA&quot;, &quot;Consolidated Net Income&quot;) THEN&#13;&#10;    &quot;A: Major&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&#13;&#10;    &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;,&#13;&#10;    &quot;Gross Income&quot;,&#13;&#10;    &quot;SG&amp;A Expense&quot;&#13;&#10;) THEN&#13;&#10;    &quot;B: Operating Build (light)&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&#13;&#10;    &quot;Pretax Income&quot;,&#13;&#10;    &quot;Income Taxes&quot;&#13;&#10;) THEN&#13;&#10;    &quot;C: Consolidated NI Build (light)&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Z: Normal&quot;&#13;&#10;END' />
            </column>
            <column caption='Statement Filter' datatype='string' name='[Calculation_182677305817022471]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column caption='Dec &apos;20' datatype='real' name='[DEC &apos;20]' role='measure' type='quantitative' />
            <column caption='Dec &apos;21' datatype='real' name='[DEC &apos;21]' role='measure' type='quantitative' />
            <column caption='Dec &apos;22' datatype='real' name='[DEC &apos;22]' role='measure' type='quantitative' />
            <column caption='Dec &apos;23' datatype='real' name='[DEC &apos;23]' role='measure' type='quantitative' />
            <column caption='Dec &apos;24' datatype='real' name='[DEC &apos;24]' role='measure' type='quantitative' />
            <column caption='Dec &apos;25' datatype='real' name='[DEC &apos;25]' role='measure' type='quantitative' />
            <column datatype='string' name='[F1]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_182677305803657217]' derivation='None' name='[none:Calculation_182677305803657217:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_182677305808211972]' derivation='None' name='[none:Calculation_182677305808211972:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_182677305817022471]' derivation='None' name='[none:Calculation_182677305817022471:nk]' pivot='key' type='nominal' />
            <column-instance column='[F1]' derivation='None' name='[none:F1:nk]' pivot='key' type='nominal' />
            <column-instance column='[DEC &apos;20]' derivation='Sum' name='[sum:DEC &apos;20:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DEC &apos;21]' derivation='Sum' name='[sum:DEC &apos;21:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DEC &apos;22]' derivation='Sum' name='[sum:DEC &apos;22:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DEC &apos;23]' derivation='Sum' name='[sum:DEC &apos;23:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DEC &apos;24]' derivation='Sum' name='[sum:DEC &apos;24:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DEC &apos;25]' derivation='Sum' name='[sum:DEC &apos;25:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1fhy3tw1x76j2h1ctexvr0ggkdc7].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.1fhy3tw1x76j2h1ctexvr0ggkdc7].[sum:DEC &apos;25:qk]&quot;' />
