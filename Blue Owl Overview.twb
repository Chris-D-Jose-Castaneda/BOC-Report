    <worksheet name='Road to Net Income'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#2f3971'>Net Income Dist.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='income_wide (OWL_financial_statements)' name='federated.0785vgl1sqp7ki13ondak04kkqa7' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='pYear' datatype='integer' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0785vgl1sqp7ki13ondak04kkqa7'>
            <column caption='Amount Year' datatype='real' name='[Calculation_182677305949392926]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Amount (pYear)&#13;&#10;CASE [Parameters].[Parameter 2]&#13;&#10;    WHEN 2020 THEN [DEC &apos;20]&#13;&#10;    WHEN 2021 THEN [DEC &apos;21]&#13;&#10;    WHEN 2022 THEN [DEC &apos;22]&#13;&#10;    WHEN 2023 THEN [DEC &apos;23]&#13;&#10;    WHEN 2024 THEN [DEC &apos;24]&#13;&#10;    WHEN 2025 THEN [DEC &apos;25]&#13;&#10;END' />
            </column>
            <column caption='Waterfall Color' datatype='string' name='[Calculation_182677305950965793]' role='measure' type='nominal'>
              <calculation class='tableau' formula='// Waterfall Color&#13;&#10;IF ATTR([line_item]) = &quot;Consolidated Net Income&quot;&#13;&#10;THEN &quot;Total&quot;&#13;&#10;&#13;&#10;ELSEIF ATTR([line_item]) = &quot;Gross Income&quot;&#13;&#10;OR ATTR([line_item]) = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Pretax Income&quot;&#13;&#10;THEN &quot;Subtotal&quot;&#13;&#10;&#13;&#10;ELSEIF ATTR([line_item]) = &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;&#13;&#10;OR ATTR([line_item]) = &quot;SG&amp;A Expense&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Interest Expense&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Income Taxes&quot;&#13;&#10;OR ATTR([line_item]) = &quot;Unusual Expense - Net&quot;&#13;&#10;THEN &quot;Expense&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Calculation_182677305954807846]) &gt;= 0&#13;&#10;THEN &quot;Positive&quot;&#13;&#10;&#13;&#10;ELSE &quot;Expense&quot;&#13;&#10;END' />
            </column>
            <column caption='WF Signed Amount' datatype='real' name='[Calculation_182677305954807846]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// WF Signed Amount&#13;&#10;IF [line_item] = &quot;Gross Income&quot;&#13;&#10;OR [line_item] = &quot;EBIT (Operating Income)&quot;&#13;&#10;OR [line_item] = &quot;Pretax Income&quot;&#13;&#10;OR [line_item] = &quot;Consolidated Net Income&quot;&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;&#13;&#10;OR [line_item] = &quot;SG&amp;A Expense&quot;&#13;&#10;OR [line_item] = &quot;Interest Expense&quot;&#13;&#10;OR [line_item] = &quot;Income Taxes&quot;&#13;&#10;OR [line_item] = &quot;Unusual Expense - Net&quot;&#13;&#10;THEN -ABS([Calculation_182677305949392926])&#13;&#10;&#13;&#10;ELSEIF [line_item] = &quot;Other Income (Expense)&quot;&#13;&#10;THEN [Calculation_182677305949392926]&#13;&#10;&#13;&#10;ELSE&#13;&#10;    [Calculation_182677305949392926]&#13;&#10;END' />
            </column>
            <column caption='Dec &apos;20' datatype='real' name='[DEC &apos;20]' role='measure' type='quantitative' />
            <column caption='Dec &apos;21' datatype='real' name='[DEC &apos;21]' role='measure' type='quantitative' />
            <column caption='Dec &apos;22' datatype='real' name='[DEC &apos;22]' role='measure' type='quantitative' />
            <column caption='Dec &apos;23' datatype='real' name='[DEC &apos;23]' role='measure' type='quantitative' />
            <column caption='Dec &apos;24' datatype='real' name='[DEC &apos;24]' role='measure' type='quantitative' />
            <column caption='Dec &apos;25' datatype='real' name='[DEC &apos;25]' role='measure' type='quantitative' />
            <column caption='Line Item' datatype='string' name='[line_item]' role='dimension' type='nominal' />
            <column-instance column='[line_item]' derivation='None' name='[none:line_item:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_182677305949392926]' derivation='Sum' name='[sum:Calculation_182677305949392926:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_182677305950965793]' derivation='User' name='[usr:Calculation_182677305950965793:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0785vgl1sqp7ki13ondak04kkqa7].[none:line_item:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Consolidated Net Income&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;EBIT (Operating Income)&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Gross Income&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Income Taxes&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Interest Expense&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Nonoperating Interest Income&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Other Income (Expense)&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Pretax Income&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Sales&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;SG&amp;A Expense&quot;' />
              <groupfilter function='member' level='[none:line_item:nk]' member='&quot;Unusual Expense - Net&quot;' />
            </groupfilter>
