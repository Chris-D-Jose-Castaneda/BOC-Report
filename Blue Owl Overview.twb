    <worksheet name='Balance Sheet'>
      <table>
        <view>
          <datasources>
            <datasource caption='OWL-US (Blue Owl Balance Sheet)' name='federated.0huhuq11bwl43617szogw0poh2yv' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Financial Statement' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Income Statement&quot;'>
              <calculation class='tableau' formula='&quot;Income Statement&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0huhuq11bwl43617szogw0poh2yv'>
            <column caption='BS Highlighted Group' datatype='string' name='[Calculation_182677305805746178]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [F1] IN (&quot;Total Assets&quot;) THEN &quot;A: Total Assets&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&quot;Total Liabilities&quot;) THEN &quot;B: Total Liabilities&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&quot;Total Equity&quot;, &quot;Total Shareholders’ Equity&quot;) THEN &quot;C: Total Equity&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&quot;Total Liabilities &amp; Shareholders’ Equity&quot;) THEN &quot;D: Balance Check (Total L+E)&quot;&#13;&#10;&#13;&#10;ELSE &quot;Z: Normal&quot;&#13;&#10;END' />
            </column>
            <column caption='Statement Filter' datatype='string' name='[Calculation_182677305816006662]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column caption='Indent Level' datatype='integer' name='[Calculation_1999879755159900171]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [F1]&#13;&#10;&#13;&#10;/* ===== Level 0: Section headers (no indent) ===== */&#13;&#10;WHEN &quot;Assets&quot; THEN 0&#13;&#10;WHEN &quot;Liabilities &amp; Shareholders&apos; Equity&quot; THEN 0&#13;&#10;WHEN &quot;Per Share&quot; THEN 0&#13;&#10;&#13;&#10;/* ===== Level 1: Subheaders (slight indent) ===== */&#13;&#10;WHEN &quot;Current&quot; THEN 1&#13;&#10;WHEN &quot;Long-Term&quot; THEN 1&#13;&#10;WHEN &quot;Equity&quot; THEN 1&#13;&#10;&#13;&#10;/* ===== Level 1: Key subtotals / totals (keep close to header) ===== */&#13;&#10;WHEN &quot;Total Current Assets&quot; THEN 1&#13;&#10;WHEN &quot;Total Assets&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Total Current Liabilities&quot; THEN 1&#13;&#10;WHEN &quot;Total Liabilities&quot; THEN 1&#13;&#10;WHEN &quot;Total Shareholders’ Equity&quot; THEN 1&#13;&#10;WHEN &quot;Total Equity&quot; THEN 1&#13;&#10;WHEN &quot;Total Liabilities &amp; Shareholders’ Equity&quot; THEN 1&#13;&#10;&#13;&#10;/* ===== Level 2: Detail lines (fully indented) ===== */&#13;&#10;/* Assets detail */&#13;&#10;WHEN &quot;Cash &amp; Short-Term Investments&quot; THEN 2&#13;&#10;WHEN &quot;Short-Term Receivables&quot; THEN 2&#13;&#10;WHEN &quot;Net Property, Plant &amp; Equipment&quot; THEN 2&#13;&#10;WHEN &quot;Total Long-Term Investments&quot; THEN 2&#13;&#10;WHEN &quot;Intangible Assets&quot; THEN 2&#13;&#10;WHEN &quot;Deferred Tax Assets&quot; THEN 2&#13;&#10;WHEN &quot;Other Assets&quot; THEN 2&#13;&#10;&#13;&#10;/* Liabilities detail */&#13;&#10;WHEN &quot;Other Current Liabilities&quot; THEN 2&#13;&#10;WHEN &quot;Long-Term Debt&quot; THEN 2&#13;&#10;WHEN &quot;Deferred Tax Liabilities&quot; THEN 2&#13;&#10;WHEN &quot;Other Liabilities&quot; THEN 2&#13;&#10;&#13;&#10;/* Equity detail */&#13;&#10;WHEN &quot;Common Equity&quot; THEN 2&#13;&#10;WHEN &quot;Retained Earnings&quot; THEN 2&#13;&#10;WHEN &quot;Accumulated Minority Interest&quot; THEN 2&#13;&#10;&#13;&#10;/* Per share detail */&#13;&#10;WHEN &quot;Book Value per Share&quot; THEN 2&#13;&#10;WHEN &quot;Tangible Book Value per Share&quot; THEN 2&#13;&#10;&#13;&#10;/* ===== Default ===== */&#13;&#10;ELSE 1&#13;&#10;END' />
            </column>
            <column caption='Indented Label' datatype='string' name='[Calculation_1999879755159965708]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='SPACE([Calculation_1999879755159900171] * 4) + [F1]' />
