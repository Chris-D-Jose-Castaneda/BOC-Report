        <calculation class='tableau' formula='IF CONTAINS(LOWER([line_item]), &quot;total&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;net income&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;gross&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;ebit&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;assets&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;liabilities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;equity&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;operating activities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;investing activities&quot;)&#13;&#10;OR CONTAINS(LOWER([line_item]), &quot;financing activities&quot;)&#13;&#10;THEN [line_item]&#13;&#10;ELSE CHAR(9) + [line_item]&#13;&#10;END' />
