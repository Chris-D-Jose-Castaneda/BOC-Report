              <bucket>&quot;Sales&quot;</bucket>
              <bucket>&quot;Cost of Goods Sold (COGS) incl. D&amp;A&quot;</bucket>
              <bucket>&quot;Gross Income&quot;</bucket>
              <bucket>&quot;SG&amp;A Expense&quot;</bucket>
              <bucket>&quot;EBIT (Operating Income)&quot;</bucket>
              <bucket>&quot;Nonoperating Interest Income&quot;</bucket>
              <bucket>&quot;Other Income (Expense)&quot;</bucket>
              <bucket>&quot;Interest Expense&quot;</bucket>
              <bucket>&quot;Unusual Expense - Net&quot;</bucket>
              <bucket>&quot;Pretax Income&quot;</bucket>
