          <datasources>
            <datasource caption='OWL-US (Blue Owl Cash Flow)' name='federated.1r0mmz30t54ymf1b19w0z11ky9lu' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Financial Statement' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Income Statement&quot;'>
              <calculation class='tableau' formula='&quot;Income Statement&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1r0mmz30t54ymf1b19w0z11ky9lu'>
            <column caption='CFS Highlight Group' datatype='string' name='[Calculation_182677305808359429]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [F1] IN (&quot;Operating Activities&quot;, &quot;Investing Activities&quot;, &quot;Financing Activities&quot;) THEN&#13;&#10;    &quot;A: Section Header&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&#13;&#10;    &quot;Net Income / Starting Line&quot;,&#13;&#10;    &quot;Net Operating Cash Flow&quot;,&#13;&#10;    &quot;Net Investing Cash Flow&quot;,&#13;&#10;    &quot;Net Financing Cash Flow&quot;,&#13;&#10;    &quot;Free Cash Flow&quot;&#13;&#10;) THEN&#13;&#10;    &quot;B: Key Cash Flow Lines&quot;&#13;&#10;&#13;&#10;ELSEIF [F1] IN (&quot;Net Change in Cash&quot;) THEN&#13;&#10;    &quot;C: Tie-Out&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Z: Normal&quot;&#13;&#10;END' />
            </column>
            <column caption='Statement Filter' datatype='string' name='[Calculation_182677305817231368]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column caption='Indent Level' datatype='integer' name='[Calculation_1999879755130851332]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [F1]&#13;&#10;&#13;&#10;/* ===== Level 0: Section headers ===== */&#13;&#10;WHEN &quot;Operating Activities&quot; THEN 0&#13;&#10;WHEN &quot;Investing Activities&quot; THEN 0&#13;&#10;WHEN &quot;Financing Activities&quot; THEN 0&#13;&#10;WHEN &quot;All Activities&quot; THEN 0&#13;&#10;&#13;&#10;/* ===== Level 2: Children (indented under subheaders) ===== */&#13;&#10;&#13;&#10;/* Depreciation, Depletion &amp; Amortization */&#13;&#10;WHEN &quot;Depreciation and Depletion&quot; THEN 2&#13;&#10;WHEN &quot;Amortization of Intangible Assets&quot; THEN 2&#13;&#10;&#13;&#10;/* Deferred Taxes &amp; Investment Tax Credit */&#13;&#10;WHEN &quot;Deferred Taxes&quot; THEN 2&#13;&#10;&#13;&#10;/* Changes in Working Capital */&#13;&#10;WHEN &quot;Receivables&quot; THEN 2&#13;&#10;WHEN &quot;Other Accruals&quot; THEN 2&#13;&#10;WHEN &quot;Other Assets/Liabilities&quot; THEN 2&#13;&#10;&#13;&#10;/* Capital Expenditures */&#13;&#10;WHEN &quot;Capital Expenditures (Fixed Assets)&quot; THEN 2&#13;&#10;&#13;&#10;/* Purchase/Sale of Investments */&#13;&#10;WHEN &quot;Purchase of Investments&quot; THEN 2&#13;&#10;WHEN &quot;Sale/Maturity of Investments&quot; THEN 2&#13;&#10;&#13;&#10;/* Financing detail lines */&#13;&#10;WHEN &quot;Common Dividends&quot; THEN 2&#13;&#10;WHEN &quot;Repurchase of Common &amp; Preferred Stk.&quot; THEN 2&#13;&#10;WHEN &quot;Proceeds from Stock Options&quot; THEN 2&#13;&#10;WHEN &quot;Change in Long-Term Debt&quot; THEN 2&#13;&#10;WHEN &quot;Issuance of Long-Term Debt&quot; THEN 2&#13;&#10;WHEN &quot;Reduction in Long-Term Debt&quot; THEN 2&#13;&#10;&#13;&#10;/* Free Cash Flow detail lines */&#13;&#10;WHEN &quot;Free Cash Flow per Share&quot; THEN 2&#13;&#10;WHEN &quot;Free Cash Flow Yield (%)&quot; THEN 2&#13;&#10;&#13;&#10;/* ===== Default Level 1: Subheaders, subtotals, and standalone lines ===== */&#13;&#10;ELSE 1&#13;&#10;END' />
            </column>
            <column caption='Indented Line Item' datatype='string' name='[Calculation_1999879755130912773]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='SPACE([Calculation_1999879755130851332] * 4) + [F1]' />
            </column>
            <column caption='Dec &apos;20' datatype='real' name='[DEC &apos;20]' role='measure' type='quantitative' />
            <column caption='Dec &apos;21' datatype='real' name='[DEC &apos;21]' role='measure' type='quantitative' />
